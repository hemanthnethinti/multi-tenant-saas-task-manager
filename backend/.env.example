# Backend Environment Variables (Template)
# Copy this file to .env and adjust values for your environment.

# Node Environment
NODE_ENV=development
PORT=5000

# Database Configuration
# For local development (outside Docker)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=multi_tenant_saas
DATABASE_USER=saas_user
DATABASE_PASSWORD=saas_password_2024

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=24h

# Frontend URL for CORS
# Local dev: http://localhost:3000
# Docker: http://frontend:3000
FRONTEND_URL=http://localhost:3000

# Optional: If your tooling expects DB_* variable names, set both (not used by app code)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=multi_tenant_saas
DB_USER=saas_user
DB_PASSWORD=saas_password_2024
