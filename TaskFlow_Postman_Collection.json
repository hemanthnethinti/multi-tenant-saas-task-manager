        {
          "name": "Register New Tenant",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantName\": \"Test Company\",\n  \"subdomain\": \"testco\",\n  \"email\": \"admin@testco.com\",\n  \"name\": \"John Doe\",\n  \"password\": \"TestPass@123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (Acme Tenant Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.environment.set('token', pm.response.json().data.token);"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
